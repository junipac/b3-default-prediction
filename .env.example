# ─── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=b3_ingestion
DB_USER=b3_user
DB_PASSWORD=CHANGE_ME
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Rate Limiting ────────────────────────────────────────────────────────────
B3_RPM=30
CVM_RPM=60
DOU_RPM=10
CONCURRENT_REQUESTS=5

# ─── Retry ───────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_INITIAL_WAIT=2.0
RETRY_MAX_WAIT=120.0
RETRY_MULTIPLIER=2.0

# ─── Data Quality ─────────────────────────────────────────────────────────────
MIN_COMPLETENESS=0.75
MAX_MISSING_PCT=0.25
BS_TOLERANCE=0.01
PRICE_SPIKE_THRESHOLD=0.50
MIN_TRADING_DAYS=180

# ─── Default Detection ────────────────────────────────────────────────────────
SUSPENSION_DAYS=30
PRICE_DROP_THRESHOLD=-0.80
PRICE_DROP_WINDOW=252
DISTRESS_THRESHOLD=0.7

# ─── Pipeline ────────────────────────────────────────────────────────────────
DAILY_CRON=0 20 * * 1-5
QUARTERLY_CRON=0 6 * * 1
ANNUAL_CRON=0 4 1 * *
MAX_PARALLEL_JOBS=4

# ─── Segurança ────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_IN_PRODUCTION_RANDOM_STRING
ENCRYPT_SENSITIVE=true
IMMUTABLE_LOGS=true
RETENTION_DAYS=3650

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
